# Bloom & Vine - Apache Configuration
# Optional: Enable if you want clean URLs

RewriteEngine On

# Adjust this if the folder name in the URL is different
RewriteBase /Flower-Store/

# Prevent directory listing
Options -Indexes -MultiViews

# Clean URLs: redirect .php to extensionless
RewriteCond %{THE_REQUEST} \s/+(.+)\.php(?:[?\s]|$) [NC]
RewriteRule ^ /%1 [R=301,L]

# Map extensionless URLs to .php files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# Security: Prevent access to sensitive files
<FilesMatch "^(\.htaccess|\.git|composer\.json|package\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect uploads directory (optional - uncomment if needed)
# <Directory "uploads">
#     Options -Indexes
#     AllowOverride None
# </Directory>

# PHP Settings (if allowed by server)
<IfModule mod_php7.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
</IfModule>

